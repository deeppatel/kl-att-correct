# Copy to .env and fill in
PORT=3000
SESSION_SECRET=change-me-to-a-long-random-string

# MySQL connection to the online DB
DB_HOST=your-db-host.example.com
DB_PORT=3306
DB_USER=att_user
DB_PASSWORD=secret
DB_NAME=hrms

# Source table holding daily punch summary rows.
# Adjust column names below to match your real schema.
SRC_TABLE=attendance_punch_summary
COL_ID=id
COL_EMP_ID=employee_id
COL_EMP_NAME=employee_name
COL_DATE=att_date
COL_IN=in_time
COL_OUT=out_time
COL_STATUS=status
